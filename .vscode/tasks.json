{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile C++", // This has to match with keybindings.json
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "build_Debug"
            ],
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task to compile this specific project"
        },
		{
            "label": "Compile n Run C++",
            "type": "process",
            "dependsOn": ["Compile C++"],
            "dependsOrder": "sequence",
            "options": {
                "cwd": "${workspaceFolder}\\build_Debug\\QC-LASER-Portable-Distribution"
            },
            "command": "QC-LASER.exe",
            "presentation": {
                "panel": "dedicated"
            },
            "detail": "Task to Compile then Execute immediately"
        }
    ]
}